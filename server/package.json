{
  "name": "jingle-machine-helper",
  "version": "0.1.0",
  "private": true,
  "description": "Local helper that extracts audio from YouTube for Jingle Machine",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "release": "gh workflow run build-packages.yml",
    "download": "node scripts/download-release.js"
  },
  "pkg": {
    "assets": [
      "public/**/*",
      "app/**/*",
      "node_modules/**/*.mjs",
      "node_modules/**/*.json"
    ],
    "targets": [
      "node22-win-x64",
      "node22-macos-x64",
      "node22-macos-arm64"
    ],
    "outputPath": "dist"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "cors": "^2.8.5",
    "express": "^5.2.1"
  },
  "packageManager": "yarn@4.14.1+sha512.64df448055b2d37ba269d7db535a469b8da93f8ef1140c25fd7a83c00a8fbaacb214ca0e02553b92a2c54cef78bb67d0b4817fab02001df0e24fac0faccc3b42"
}
